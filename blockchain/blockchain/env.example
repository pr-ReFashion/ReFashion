# ── Local dev (no changes needed) ────────────────────────────────────────────
# Hardhat auto-generates test wallets for localhost; nothing to configure.

# ── Polygon Amoy testnet (fill in when ready to deploy to testnet) ────────────
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
DEPLOYER_PRIVATE_KEY=your_deployer_wallet_private_key_here

# ── Polygonscan (optional — only needed for contract verification) ─────────────
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
